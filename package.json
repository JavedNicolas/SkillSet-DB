{
  "name": "skillset-db",
  "version": "0.1.1",
  "description": "Skill-rules database for Claude Code: extracts atomic rules from skills and auto-injects the relevant ones into every prompt",
  "type": "module",
  "license": "MIT",
  "author": "Nicolas Javed",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JavedNicolas/SkillSet-DB.git"
  },
  "bugs": {
    "url": "https://github.com/JavedNicolas/SkillSet-DB/issues"
  },
  "homepage": "https://github.com/JavedNicolas/SkillSet-DB#readme",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "skillset-db": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "tsup",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "skills",
    "rules",
    "mcp",
    "hooks"
  ],
  "dependencies": {
    "@inquirer/checkbox": "^4.3.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "p-limit": "^6.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.30",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
